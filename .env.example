# Mobula API key (required)
MOBULA_API_KEY=your_api_key_here

# Your webhook receiver URL (must be publicly accessible)
WEBHOOK_URL=https://your-server.com/webhook/transfers

# Server port for the webhook receiver
PORT=3000

# Wallets to track (comma-separated Solana addresses)
WALLETS=Wallet1Address,Wallet2Address,Wallet3Address
